{
  "name": "tiktok-games-launcher",
  "version": "1.0.0",
  "type": "module",
  "description": "Launcher de TikTok Games para creadores",
  "main": "electron/main.js",
  "scripts": {
    "start": "tsx server.ts",
    "electron": "electron --disable-gpu --no-sandbox --disable-software-rasterizer .",
    "compile": "tsc",
    "pack": "npm run compile && electron-builder --dir",
    "dist": "npm run compile && electron-builder"
  },
  "dependencies": {
    "express": "^4.19.2",
    "piratetok-live-js": "^0.1.5",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.9",
    "electron": "^43.1.1",
    "electron-builder": "^24.13.3",
    "tsx": "^4.22.5",
    "typescript": "^5.5.2"
  },
  "build": {
    "appId": "com.tiktokgames.launcher",
    "productName": "TikTok Games Launcher",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "electron/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TikTok Games Launcher"
    },
    "files": [
      "**/*",
      "!central-server/**/*",
      "!temp_update/**/*",
      "!server.ts",
      "!tsconfig.json",
      "!src/**/*"
    ]
  }
}
